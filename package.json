{
  "name": "ACM - (Angler Content Manager)",
  "version": "1.0.0",
  "author": "Cole Templin (https://github.com/sxriptor)",
  "description": "ACM - (Angler Content Manager)",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "make-ico": "node scripts/make-ico.js",
    "dist:win": "npm run make-ico && electron-builder --win",
    "pack:win": "npm run make-ico && electron-builder --win --dir"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.watrways.acm",
    "productName": "ACM - (Angler Content Manager)",
    "directories": {
      "output": "dist"
    },
    "icon": "public/logo.ico",
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/splash.mp4",
        "to": "splash.mp4"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ACM-installer.exe",
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico"
    },
    "portable": {
      "artifactName": "ACM-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Sxriptor",
      "repo": "COTW-ACP",
      "releaseType": "release"
    }
  }
}
