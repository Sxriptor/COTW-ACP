{
  "name": "angler-mod-manager-electron",
  "version": "1.0.0",
  "description": "Electron mod manager for Call of the Wild: The Angler",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "dist:win": "electron-builder --win",
    "pack:win": "electron-builder --win --dir"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anglertools.modmanager",
    "productName": "Angler Mod Manager",
    "directories": {
      "output": "dist"
    },
    "icon": "public/logo.png",
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/splash.mp4",
        "to": "splash.mp4"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ACM-installer.exe"
    },
    "portable": {
      "artifactName": "ACM-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Sxriptor",
      "repo": "COTW-ACP",
      "releaseType": "release"
    }
  }
}
